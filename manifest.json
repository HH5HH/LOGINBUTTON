{
  "manifest_version": 3,
  "name": "Login Button",
  "version": "1.2.85",
  "description": "Login Button is an MV3 Chrome extension for Adobe IMS authorization-code PKCE sign-in, profile inspection, and session diagnostics.",
  "minimum_chrome_version": "114",
  "key": "",
  "permissions": [
    "storage",
    "identity",
    "scripting",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://*.adobelogin.com/*",
    "https://*.adobe.com/*",
    "https://*.adobeprimetime.com/*",
    "https://*.adobe.net/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open Login Button"
  },
  "side_panel": {
    "default_path": "app.html"
  },
  "icons": {
    "16": "icons/icon_16.png",
    "48": "icons/icon_48.png",
    "128": "icons/icon_128.png"
  },
  "version_name": "1.2.85"
}
