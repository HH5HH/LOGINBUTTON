# adobe.ims.redirect_uri=https://danaegilocobhopoepodlpondjjfcpoi.chromiumapp.org/ims

# Optional Adobe Pass console target used for post-login extendedProfile and Programmer hydration.
# Default if omitted: release-production -> https://console.auth.adobe.com/rest/api
# adobe.console.environment=release-production
# adobe.console.url=https://console.auth.adobe.com/rest/api

# Optional app-owned org roster preserved for org diagnostics.
# JSON array string format:
# adobe.ims.organizations=[{"id":"adobepass","label":"Adobe PASS"},{"id":"exampleorg","label":"Example Org"}]
# Large key/value roster format:
# adobe.ims.organizations.adobepass=Adobe PASS
# adobe.ims.organizations.exampleorg=Example Org
